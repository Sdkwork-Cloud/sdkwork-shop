{
  "name": "@sdkwork/shop-backend-sdk",
  "version": "0.1.0",
  "description": "SDKWork Shop Backend API composed consumer SDK.",
  "type": "module",
  "private": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@sdkwork/sdk-common": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src",
    "dist",
    "generated/server-openapi/dist",
    "generated/server-openapi/src",
    "generated/server-openapi/sdkwork-sdk.json",
    "generated/server-openapi/README.md",
    "generated/server-openapi/LICENSE",
    "README.md",
    "LICENSE"
  ]
}
